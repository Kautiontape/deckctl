# Audio input picker. Mirrors audio-out: dynamic region expands to one
# button per PipeWire source, current default highlighted.

[page]
name = "audio-in"
back = "main"

[[keys]]
pos = [0, 0]
type = "command"
icon = "go-previous"
label = "Back"
on_press = "back"

# Dynamic region for input sources. 14 slots (filling rows 0-2 from
# pos [1, 0] onward) easily covers typical setups (1-4 mics).
[[keys]]
pos = [1, 0]
type = "dynamic"
producer = "audio_source"
slots = 14
