[page]
name = "ha"
back = "main"

# All ha_action calls require ~/.config/deckctl/secrets.env to provide HA_URL
# and HA_TOKEN. See secrets.env.example.

[[keys]]
pos = [0, 0]
type = "command"
icon = "go-previous"
label = "Back"
on_press = "back"

# Office speaker mute toggle. Reflects current is_volume_muted state and
# tints green when muted; tap fires the HA script that handles the toggle.
[[keys]]
pos = [1, 0]
type = "ha_toggle"
entity = "media_player.britney_speaker"
attribute = "is_volume_muted"
service = "script.toggle_mute_office_speaker"
icon_on = "audio-volume-muted"
icon_off = "audio-volume-high"
label = "Office"

# Office speaker volume up/down via media_player domain.
# (HA's "Britney Speaker" entity is the office speaker — legacy naming.)
[[keys]]
pos = [2, 0]
type = "ha_action"
service = "media_player.volume_down"
target = "media_player.britney_speaker"
icon = "audio-volume-low"
label = "Office −"

[[keys]]
pos = [3, 0]
type = "ha_action"
service = "media_player.volume_up"
target = "media_player.britney_speaker"
icon = "audio-volume-high"
label = "Office +"
