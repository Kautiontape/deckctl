[page]
name = "feishin"
back = "main"

# Row 0
[[keys]]
pos = [0, 0]
type = "command"
icon = "go-previous"
label = "Back"
on_press = "back"

# Open Feishin's window via MPRIS Raise() — bypasses the scratchpad helper
# and works whether Feishin is currently scratchpadded, minimized, or open.
[[keys]]
pos = [1, 0]
type = "command"
icon = "music"
label = "Open"
on_press = "dbus-send --session --dest=org.mpris.MediaPlayer2.Feishin --type=method_call /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Raise"

[[keys]]
pos = [2, 0]
type = "mpris_loop"
player = "Feishin"

[[keys]]
pos = [3, 0]
type = "mpris_shuffle"
player = "Feishin"

[[keys]]
pos = [4, 0]
type = "page"
target = "playlists"
icon = "view-list"
label = "Playlists"

# Row 1 — Prev / Album-art-as-play-pause / Next centered
[[keys]]
pos = [1, 1]
type = "command"
icon = "media-skip-backward"
label = "Prev"
on_press = "playerctl --player=Feishin previous"

[[keys]]
pos = [2, 1]
type = "mpris"
player = "Feishin"
size = "large"
# Default press behaviour is play_pause via D-Bus; explicit here for clarity.

[[keys]]
pos = [3, 1]
type = "command"
icon = "media-skip-forward"
label = "Next"
on_press = "playerctl --player=Feishin next"

# Row 2
[[keys]]
pos = [0, 2]
type = "volume"
direction = "mute"

[[keys]]
pos = [1, 2]
type = "volume"
direction = "down"
step = 5

[[keys]]
pos = [2, 2]
type = "mpris_title"
player = "Feishin"

[[keys]]
pos = [3, 2]
type = "volume"
direction = "up"
step = 5

[[keys]]
pos = [4, 2]
type = "mpris_star"
player = "Feishin"
