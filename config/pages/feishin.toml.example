[page]
name = "feishin"
back = "main"

# Row 0
[[keys]]
pos = [0, 0]
type = "command"
icon = "go-previous"
label = "Back"
on_press = "back"

[[keys]]
pos = [1, 0]
type = "mpris"
player = "Feishin"
size = "large"              # render album art at full size, no overlay text
on_press = "playerctl --player=Feishin play-pause"

[[keys]]
pos = [2, 0]
type = "command"
icon = "media-playlist-repeat"
label = "Loop"
# TODO: turn into a `mpris_toggle` widget once we verify Feishin honors
# LoopStatus writes via D-Bus.
on_press = "playerctl --player=Feishin loop None"

[[keys]]
pos = [3, 0]
type = "command"
icon = "media-playlist-shuffle"
label = "Shuffle"
on_press = "playerctl --player=Feishin shuffle Toggle"

[[keys]]
pos = [4, 0]
type = "page"
target = "playlists"
icon = "view-list"
label = "Playlists"

# Row 1
[[keys]]
pos = [0, 1]
type = "command"
icon = "media-skip-backward"
on_press = "playerctl --player=Feishin previous"

[[keys]]
pos = [1, 1]
type = "command"
icon = "media-playback-start"
on_press = "playerctl --player=Feishin play-pause"

[[keys]]
pos = [2, 1]
type = "command"
icon = "media-skip-forward"
on_press = "playerctl --player=Feishin next"

[[keys]]
pos = [3, 1]
type = "mic_mute"

[[keys]]
pos = [4, 1]
type = "command"
icon = "applications-multimedia"
label = "Open"
on_press = "~/.config/sway/bin/sway-scratchpad-launch.sh feishin"

# Row 2
[[keys]]
pos = [0, 2]
type = "volume"
direction = "mute"

[[keys]]
pos = [1, 2]
type = "volume"
direction = "down"
step = 5

[[keys]]
pos = [2, 2]
type = "command"
label = "Title"
# TODO: track-title text widget. For now, blank.

[[keys]]
pos = [3, 2]
type = "volume"
direction = "up"
step = 5

[[keys]]
pos = [4, 2]
type = "command"
icon = "starred"
label = "Star"
# TODO: wire to Subsonic API once secrets-handling is in place.
