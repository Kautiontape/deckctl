# Audio output picker. The dynamic-list region expands to one button per
# PipeWire sink at runtime; the current default sink is highlighted with
# a green top border. Tap a sink to make it the new default.

[page]
name = "audio-out"
back = "main"

[[keys]]
pos = [0, 0]
type = "command"
icon = "go-previous"
label = "Back"
on_press = "back"

# Volume controls in row 0 next to Back.
[[keys]]
pos = [1, 0]
type = "volume"
direction = "down"
step = 5

[[keys]]
pos = [2, 0]
type = "volume"
direction = "mute"

[[keys]]
pos = [3, 0]
type = "volume"
direction = "up"
step = 5

# Dynamic region for sinks. Starts at (0, 1) and fills row-major to (4, 2),
# 10 slots. Most users have 2-4 sinks, plenty of room.
[[keys]]
pos = [0, 1]
type = "dynamic"
producer = "audio_sink"
slots = 10
