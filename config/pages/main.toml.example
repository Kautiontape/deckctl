[page]
name = "main"

# Row 0
[[keys]]
pos = [0, 0]
type = "weather"
location = "39.122318,-76.561760"
unit = "F"
refresh_minutes = 15

[[keys]]
pos = [1, 0]
type = "mpris"
player = "Feishin"
on_press = "playerctl --player=Feishin play-pause"
on_long_press = "page:feishin"

# Combined Next/Prev: tap = next, long-press = previous. Saves a slot.
[[keys]]
pos = [2, 0]
type = "command"
icon = "media-skip-forward"
label = "Next"
on_press = "playerctl --player=Feishin next"
on_long_press = "playerctl --player=Feishin previous"

# Audio output picker, sits next to mic for an "audio devices" cluster.
[[keys]]
pos = [3, 0]
type = "page"
target = "audio-out"
icon = "audio-headphones"
label = "Out"

# Mic mute on tap; long-press opens the input picker.
[[keys]]
pos = [4, 0]
type = "mic_mute"
on_long_press = "page:audio-in"

# Row 1 — recents: 4 most-recently-focused windows (excluding the
# current one). Tap to focus that window. Auto-fills as you work; no
# config required.
[[keys]]
pos = [0, 1]
type = "dynamic"
producer = "recents"
slots = 4

# Row 2
[[keys]]
pos = [0, 2]
type = "page"
target = "marks"
icon = "bookmark-new"
label = "Marks"

[[keys]]
pos = [1, 2]
type = "page"
target = "scratchpads"
icon = "view-grid"
label = "Apps"

[[keys]]
pos = [2, 2]
type = "page"
target = "sway"
icon = "desktop"
label = "Sway"

[[keys]]
pos = [3, 2]
type = "page"
target = "ha"
icon = "house"
label = "Home"

[[keys]]
pos = [4, 2]
type = "page"
target = "power"
icon = "system-shutdown"
label = "Power"

# Row 1 placeholder until recents lands. BT moves up if/when we want it
# back on Main; for now we'll just access via Audio Out → BT path.
[[keys]]
pos = [4, 1]
type = "page"
target = "bluetooth"
icon = "bluetooth"
label = "BT"
