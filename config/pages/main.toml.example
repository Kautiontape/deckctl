[page]
name = "main"

# Row 0
[[keys]]
pos = [0, 0]
type = "weather"
location = "39.122318,-76.561760"
unit = "F"
refresh_minutes = 15

[[keys]]
pos = [1, 0]
type = "mpris"
player = "Feishin"
on_press = "playerctl --player=Feishin play-pause"
on_long_press = "page:feishin"

[[keys]]
pos = [2, 0]
type = "command"
icon = "media-skip-backward"
on_press = "playerctl --player=Feishin previous"

[[keys]]
pos = [3, 0]
type = "command"
icon = "media-skip-forward"
on_press = "playerctl --player=Feishin next"

[[keys]]
pos = [4, 0]
type = "mic_mute"

# Row 1
[[keys]]
pos = [0, 1]
type = "page"
target = "audio-out"
icon = "audio-headphones"
label = "Out"

[[keys]]
pos = [1, 1]
type = "volume"
direction = "down"
step = 5

[[keys]]
pos = [2, 1]
type = "volume"
direction = "mute"

[[keys]]
pos = [3, 1]
type = "volume"
direction = "up"
step = 5

[[keys]]
pos = [4, 1]
type = "page"
target = "bluetooth"
icon = "bluetooth"
label = "BT"

# Row 2
[[keys]]
pos = [0, 2]
type = "page"
target = "marks"
icon = "bookmark-new"
label = "Marks"

[[keys]]
pos = [1, 2]
type = "page"
target = "scratchpads"
icon = "view-grid"
label = "Apps"

[[keys]]
pos = [2, 2]
type = "page"
target = "sway"
icon = "desktop"
label = "Sway"

[[keys]]
pos = [3, 2]
type = "page"
target = "ha"
icon = "house"
label = "Home"

[[keys]]
pos = [4, 2]
type = "page"
target = "power"
icon = "system-shutdown"
label = "Power"
