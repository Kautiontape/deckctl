# Stream Deck MK.2 — give the user access to the hidraw node.
# Install to /etc/udev/rules.d/, then `sudo udevadm control --reload`.
SUBSYSTEM=="usb", ATTRS{idVendor}=="0fd9", ATTRS{idProduct}=="0080", MODE="0660", TAG+="uaccess"
KERNEL=="hidraw*", ATTRS{idVendor}=="0fd9", ATTRS{idProduct}=="0080", MODE="0660", TAG+="uaccess"
